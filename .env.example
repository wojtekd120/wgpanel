# WGPanel .env example
# Copy to .env, edit the endpoint/public key, then run:
# docker compose up -d --build
#
# First visit opens browser setup. You do not need to generate a password hash
# for normal new installs.

### Beginner-required settings
WGPANEL_INTERFACE=wg0
WGPANEL_HOST=0.0.0.0
WGPANEL_PORT=8080
WGPANEL_SERVER_ENDPOINT=YOUR_SERVER_IP_OR_DOMAIN:51820
WGPANEL_SERVER_PUBLIC_KEY=CHANGE_ME

# Use false for local/LAN HTTP testing. Do not expose plain HTTP to the internet.
WGPANEL_SECURE_COOKIES=false

### Production notes
# For production, put WGPanel behind HTTPS with Caddy/Nginx and prefer:
# WGPANEL_HOST=127.0.0.1
# WGPANEL_SECURE_COOKIES=true

### Advanced optional settings
WGPANEL_WG_CONFIG=/etc/wireguard/wg0.conf
WGPANEL_DATABASE_PATH=/var/lib/wgpanel/wgpanel.db
WGPANEL_HELPER_PATH=/usr/local/sbin/wgpanel-helper
WGPANEL_RUN_DIR=/run/wgpanel
WGPANEL_CLIENT_ADDRESS_POOL=10.8.0.0/24
WGPANEL_SERVER_ADDRESS=10.8.0.1
WGPANEL_CLIENT_DNS=1.1.1.1
WGPANEL_AUTO_DISABLE_EXPIRED=false

# Legacy/advanced only. Leave blank for browser-based first-run setup.
WGPANEL_ADMIN_PASSWORD_HASH=
