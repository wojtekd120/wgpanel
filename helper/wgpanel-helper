#!/usr/bin/env python3
import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

try:
    import grp
except ImportError:
    grp = None

INTERFACE = "wg0"
CONFIG_PATH = Path("/etc/wireguard/wg0.conf")
RUN_DIR = Path("/run/wgpanel")


def fail(message: str) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(1)


def validate_config_path(path_s: str) -> Path:
    path = Path(path_s).resolve()
    run_dir = RUN_DIR.resolve()
    if path.parent != run_dir:
        fail("config must be under /run/wgpanel")
    if path.suffix != ".conf":
        fail("config must be a .conf file")
    if not path.is_file():
        fail("config does not exist")
    return path


def apply(config_path: Path) -> None:
    if os.geteuid() != 0:
        fail("helper must run as root")

    with tempfile.NamedTemporaryFile("w", prefix="wgpanel.strip.", suffix=".conf", delete=False) as stripped:
        stripped_path = Path(stripped.name)

    try:
        stripped_data = subprocess.run(
            ["wg-quick", "strip", str(config_path)],
            check=True,
            capture_output=True,
            text=True,
            timeout=10,
        ).stdout
        stripped_path.write_text(stripped_data, encoding="utf-8")
        os.chmod(stripped_path, 0o600)
        subprocess.run(
            ["wg", "syncconf", INTERFACE, str(stripped_path)],
            check=True,
            capture_output=True,
            text=True,
            timeout=15,
        )
        backup_path = CONFIG_PATH.with_suffix(".conf.bak")
        if CONFIG_PATH.exists():
            shutil.copy2(CONFIG_PATH, backup_path)
        shutil.copy2(config_path, CONFIG_PATH)
        if grp is not None:
            os.chown(CONFIG_PATH, 0, grp.getgrnam("wgpanel").gr_gid)
        os.chmod(CONFIG_PATH, 0o640)
    finally:
        stripped_path.unlink(missing_ok=True)


def main() -> None:
    parser = argparse.ArgumentParser(description="Restricted WGPanel WireGuard helper")
    sub = parser.add_subparsers(dest="command", required=True)
    apply_parser = sub.add_parser("apply")
    apply_parser.add_argument("--config", required=True)
    args = parser.parse_args()

    if args.command == "apply":
        apply(validate_config_path(args.config))


if __name__ == "__main__":
    main()
