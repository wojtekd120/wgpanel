#!/usr/bin/env python3
import argparse
import os
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime
from pathlib import Path

try:
    import grp
except ImportError:
    grp = None

try:
    import fcntl
except ImportError:
    fcntl = None

INTERFACE_RE = re.compile(r"^[a-zA-Z0-9_.-]+$")
RUN_DIR = Path("/run/wgpanel")
BACKUP_DIR = Path("/etc/wireguard/backups")
LOCK_PATH = Path("/run/wgpanel/apply.lock")


def fail(message: str) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(1)


def validate_config_path(path_s: str) -> Path:
    path = Path(path_s).resolve()
    run_dir = RUN_DIR.resolve()
    if path.parent != run_dir:
        fail("config must be under /run/wgpanel")
    if path.suffix != ".conf":
        fail("config must be a .conf file")
    if not path.is_file():
        fail("config does not exist")
    return path


def validate_backup_path(path_s: str, interface: str) -> Path:
    path = Path(path_s).resolve()
    backup_dir = BACKUP_DIR.resolve()
    if path.parent != backup_dir:
        fail("backup must be under /etc/wireguard/backups")
    if not path.name.startswith(f"{validate_interface(interface)}.conf.") or not path.name.endswith(".bak"):
        fail("backup filename does not match interface")
    if not path.is_file():
        fail("backup does not exist")
    return path


def validate_interface(name: str) -> str:
    if not INTERFACE_RE.fullmatch(name):
        fail("invalid interface name")
    return name


def config_path_for_interface(interface: str) -> Path:
    return Path("/etc/wireguard") / f"{validate_interface(interface)}.conf"


def apply(interface: str, config_path: Path) -> None:
    if os.geteuid() != 0:
        fail("helper must run as root")

    LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOCK_PATH.open("w", encoding="utf-8") as lock_handle:
        if fcntl is not None:
            fcntl.flock(lock_handle, fcntl.LOCK_EX)
        _apply_locked(validate_interface(interface), config_path)


def restore(interface: str, backup_path: Path) -> None:
    if os.geteuid() != 0:
        fail("helper must run as root")
    LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOCK_PATH.open("w", encoding="utf-8") as lock_handle:
        if fcntl is not None:
            fcntl.flock(lock_handle, fcntl.LOCK_EX)
        _apply_locked(validate_interface(interface), backup_path)


def create_backup(interface: str) -> None:
    if os.geteuid() != 0:
        fail("helper must run as root")
    interface = validate_interface(interface)
    target_config = config_path_for_interface(interface)
    if not target_config.is_file():
        fail("target config does not exist")
    BACKUP_DIR.mkdir(mode=0o750, parents=True, exist_ok=True)
    if grp is not None:
        os.chown(BACKUP_DIR, 0, grp.getgrnam("wgpanel").gr_gid)
    timestamp = datetime.utcnow().strftime("%Y%m%d-%H%M%S")
    backup_path = BACKUP_DIR / f"{interface}.conf.{timestamp}.bak"
    shutil.copy2(target_config, backup_path)
    if grp is not None:
        os.chown(backup_path, 0, grp.getgrnam("wgpanel").gr_gid)
    os.chmod(backup_path, 0o640)
    print(str(backup_path))


def self_test() -> None:
    validate_interface("wg0")
    RUN_DIR.mkdir(parents=True, exist_ok=True)
    BACKUP_DIR.mkdir(mode=0o750, parents=True, exist_ok=True)
    print("wgpanel-helper self-test ok")


def _apply_locked(interface: str, config_path: Path) -> None:
    target_config = config_path_for_interface(interface)
    with tempfile.NamedTemporaryFile("w", prefix="wgpanel.strip.", suffix=".conf", delete=False) as stripped:
        stripped_path = Path(stripped.name)

    try:
        stripped_data = subprocess.run(
            ["wg-quick", "strip", str(config_path)],
            check=True,
            capture_output=True,
            text=True,
            timeout=10,
        ).stdout
        stripped_path.write_text(stripped_data, encoding="utf-8")
        os.chmod(stripped_path, 0o600)

        BACKUP_DIR.mkdir(mode=0o750, parents=True, exist_ok=True)
        if grp is not None:
            os.chown(BACKUP_DIR, 0, grp.getgrnam("wgpanel").gr_gid)
        if target_config.exists():
            timestamp = datetime.utcnow().strftime("%Y%m%d-%H%M%S")
            backup_path = BACKUP_DIR / f"{interface}.conf.{timestamp}.bak"
            shutil.copy2(target_config, backup_path)
            if grp is not None:
                os.chown(backup_path, 0, grp.getgrnam("wgpanel").gr_gid)
            os.chmod(backup_path, 0o640)

        subprocess.run(
            ["wg", "syncconf", interface, str(stripped_path)],
            check=True,
            capture_output=True,
            text=True,
            timeout=15,
        )
        shutil.copy2(config_path, target_config)
        if grp is not None:
            os.chown(target_config, 0, grp.getgrnam("wgpanel").gr_gid)
        os.chmod(target_config, 0o640)
    finally:
        stripped_path.unlink(missing_ok=True)


def main() -> None:
    parser = argparse.ArgumentParser(description="Restricted WGPanel WireGuard helper")
    sub = parser.add_subparsers(dest="command", required=True)
    apply_parser = sub.add_parser("apply")
    apply_parser.add_argument("--interface", required=True)
    apply_parser.add_argument("--config", required=True)
    restore_parser = sub.add_parser("restore")
    restore_parser.add_argument("--interface", required=True)
    restore_parser.add_argument("--backup", required=True)
    backup_parser = sub.add_parser("backup")
    backup_parser.add_argument("--interface", required=True)
    sub.add_parser("self-test")
    args = parser.parse_args()

    if args.command == "apply":
        apply(args.interface, validate_config_path(args.config))
    elif args.command == "restore":
        restore(args.interface, validate_backup_path(args.backup, args.interface))
    elif args.command == "backup":
        create_backup(args.interface)
    elif args.command == "self-test":
        self_test()


if __name__ == "__main__":
    main()
