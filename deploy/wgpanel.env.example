WGPANEL_INTERFACE=wg0
WGPANEL_WG_CONFIG=/etc/wireguard/wg0.conf
WGPANEL_HOST=127.0.0.1
WGPANEL_PORT=8080
WGPANEL_DB_PATH=/var/lib/wgpanel/wgpanel.db
WGPANEL_RUNTIME_DIR=/run/wgpanel
WGPANEL_HELPER_PATH=/usr/local/sbin/wgpanel-helper
WGPANEL_CLIENT_ADDRESS_POOL=10.8.0.0/24
WGPANEL_SERVER_ADDRESS=10.8.0.1
WGPANEL_SERVER_ENDPOINT=vpn.example.com:51820
WGPANEL_SERVER_PUBLIC_KEY=replace_with_server_public_key
WGPANEL_CLIENT_DNS=1.1.1.1
WGPANEL_AUTO_DISABLE_EXPIRED=false
WGPANEL_SECURE_COOKIES=true

# Optional legacy/advanced only. Leave blank for browser setup.
WGPANEL_ADMIN_PASSWORD_HASH=
